# Template for local .env files. Copy to .env and fill in real values.
# Production values go in dist.env (gitignored).

# Required
DEBUG=on
SECRET_KEY=change-me-for-production
DATABASE_URL=sqlite:///db.sqlite3
WEATHER_API_ID=your-weather-api-key

# Cache backend (django-environ URL form)
#   locmemcache://              in-process, no external service (dev default)
#   dummycache://               no-op, useful for tests
#   rediscache://host:6379/0    Django 5.2's built-in RedisCache (production)
#
# Defaults to locmemcache:// if unset.
CACHE=locmemcache://

# How long (seconds) to cache the rendered SVG maps. Defaults to 3600.
# CACHE_MAP_TIMEOUT=3600
